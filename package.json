{
  "name": "stockfish-lc0-mcp",
  "version": "2.1.2",
  "description": "A TypeScript-based MCP server that exposes Stockfish and Lc0 chess engine capabilities to AI assistants — position/game analysis, opening database lookup, and puzzle generation. Deployable via Docker or Node.js.",
  "main": "dist/index.js",
  "bin": {
    "stockfish-lc0-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "!dist/**/*.d.ts"
  ],
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alegerber/stockfish-lc0-mcp.git"
  },
  "homepage": "https://github.com/alegerber/stockfish-lc0-mcp#readme",
  "bugs": {
    "url": "https://github.com/alegerber/stockfish-lc0-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "chess",
    "stockfish",
    "lc0",
    "uci",
    "chess-engine",
    "chess-analysis"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run --exclude tests/integration.test.ts",
    "test:integration": "vitest run tests/integration.test.ts",
    "test:all": "vitest run",
    "smoke": "node scripts/smoke-test.mjs",
    "smoke:docker": "docker build -t stockfish-lc0-mcp . && SMOKE_DOCKER_IMAGE=stockfish-lc0-mcp node scripts/smoke-test.mjs",
    "lint": "eslint"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chess.js": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
